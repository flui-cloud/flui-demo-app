# Server
PORT=3000
NODE_ENV=development

# Postgres — set either DATABASE_URL or the discrete PG* vars
DATABASE_URL=postgres://demo:demo@localhost:5432/demo
# PGHOST=localhost
# PGPORT=5432
# PGUSER=demo
# PGPASSWORD=demo
# PGDATABASE=demo

# Redis — REDIS_URL or discrete vars
REDIS_URL=redis://:demo@localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=demo

# NATS — NATS_URL or discrete host/port
NATS_URL=nats://localhost:4222
# NATS_HOST=localhost
# NATS_PORT=4222

# How many rows the hot feed keeps in Redis
FEED_MAX=50

# Ambient traffic so the page moves on its own. Toggle at runtime via
# POST /generator/stop and POST /generator/start.
GENERATOR_ENABLED=true
GENERATOR_MIN_MS=700
GENERATOR_MAX_MS=1800
